{
  "name": "rise-and-shine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:scoring": "node scripts/verify-scoring.mjs",
    "verify:queue": "node scripts/verify-queue-lifecycle.mjs",
    "verify:planner": "node scripts/verify-planner-apply.mjs && node scripts/verify-planner-rollback.mjs && node scripts/verify-planner-rpc.mjs && node scripts/verify-planner-policy.mjs",
    "verify:refinement-events": "node scripts/verify-refinement-events.mjs",
    "verify:task-enrichment": "node scripts/verify-task-enrichment.mjs",
    "verify:memory-layer": "node --env-file=.env.local scripts/verify-memory-layer.mjs",
    "mcp:server": "node --env-file=.env.local mcp/server.mjs",
    "mcp:list-tools": "node --env-file=.env.local mcp/list-tools.mjs",
    "verify:release": "npm run verify:scoring && npm run verify:queue && npm run verify:planner && npm run verify:refinement-events && npm run verify:task-enrichment && npm run lint && npm run build",
    "ingest:projects": "node scripts/ingest-project-folders.mjs",
    "ingest:projects:dry": "node scripts/ingest-project-folders.mjs --dry-run",
    "ingest:projects:webhook:test": "curl -s -X POST http://localhost:3000/api/ingest/projects -H 'Content-Type: application/json' -d '{\"dry_run\":true}' | jq"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "jose": "^6.2.3",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
